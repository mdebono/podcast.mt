---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
import ShowCard from '../components/ShowCard.astro';
import EpisodeRow from '../components/EpisodeRow.astro';
import { getFeaturedShows, getActiveShows, getLatestEpisodes, episodes, getAllTags } from '../lib/data.js';

const featured = getFeaturedShows();
const hero = featured[0];
const allShows = getActiveShows();
const latest = getLatestEpisodes(6);
const tags = getAllTags();
---

<Base title="podcast.mt — Poddati minn Malta" lang="mt">

  <!-- ── Hero ── -->
  <section class="hero grain">
    <div class="container hero-inner">
      <div class="hero-text anim-fadeup">
        <p class="hero-eyebrow" data-i18n="hero.eyebrow">🎙 Id-Direttorju tal-Podcasts Maltin</p>
        <h1 class="hero-title" data-i18n-html="hero.title">
          Poddati<br/>
          <em>minn Malta.</em>
        </h1>
        <p class="hero-sub" data-i18n="hero.sub">
          Skopri podcasts mill-gżejjer Maltin — fil-Malti, bl-Ingliż, u aktar.
        </p>
        <div class="hero-actions">
          <a href="/shows" class="btn btn--primary" data-i18n="hero.browseAllShows">Ara l-Podcasts Kollha</a>
          <a href="/submit" class="btn btn--outline" data-i18n="hero.submitYourShow">Ibgħat il-Podcast Tiegħek</a>
        </div>
        <div class="hero-stats">
          <span><strong>{allShows.length}</strong> <span data-i18n="misc.shows">podcasts</span></span>
          <span class="stat-sep">·</span>
          <span data-i18n="hero.stats.updated">Aġġornat kull 6 sigħat</span>
          <span class="stat-sep">·</span>
          <span data-i18n="hero.stats.free">B’xejn biex tniżżel</span>
        </div>
      </div>

      {hero && (
        <a href={`/shows/${hero.slug}`} class="hero-feature anim-fadeup anim-fadeup-2">
          <div class="hero-feature__label">
            <span class="badge badge--feat" data-i18n="misc.featured">Rrakkomandat</span>
          </div>
          {hero.coverArt && (
            <img class="hero-feature__art" src={hero.coverArt} alt={hero.name} width="260" height="260" />
          )}
          <div class="hero-feature__info">
            <h3>{hero.name}</h3>
            {hero.host && <p data-i18n="misc.by">minn {hero.host}</p>}
          </div>
        </a>
      )}
    </div>
  </section>

  <!-- ── Latest episodes ── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title" data-i18n="sections.latestEpisodes">Episodi Riċenti</h2>
        <a href="/episodes" class="section-more" data-i18n="sections.seeAll">Ara kollha →</a>
      </div>
      <div class="episodes-list">
        {latest.map(ep => <EpisodeRow episode={ep} />)}
      </div>
    </div>
  </section>

  <!-- ── Shows grid ── -->
  <section class="section section--tinted">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title" data-i18n="sections.allShows">Podcasts Kollha</h2>
        <a href="/shows" class="section-more" data-i18n="sections.browseDirectory">Esplora d-direttorju →</a>
      </div>

      <!-- Tag filter -->
      <div class="tag-filter" id="tagFilter">
        <button class="tag-btn tag-btn--active" data-i18n="filters.all">Kollha</button>
        {tags.map(t => (
          <button class="tag-btn" data-tag={t}>{t}</button>
        ))}
      </div>

      <div class="shows-grid" id="showsGrid">
        {allShows.map(show => (
          <div class="show-grid-item" data-tags={show.tags?.join(',')}>
            <ShowCard show={show} episodes={episodes} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA banner ── -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div>
        <h2 data-i18n="cta.gotPodcast">Għandek podcast minn Malta?</h2>
        <p data-i18n="cta.listHere">Niżżel hawn b’xejn. Laħħaq mal-udjenza Maltija li qed tfittex kontenut lokali.</p>
      </div>
      <a href="/submit" class="btn btn--primary" data-i18n="cta.submitShow">Ibgħat il-Podcast Tiegħek</a>
    </div>
  </section>

</Base>

<script>
  import { getTranslation, getCurrentLang } from '../lib/i18n.js';

  function updateTranslations() {
    const lang = getCurrentLang();
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n;
      el.textContent = getTranslation(lang, key);
    });
  }

  updateTranslations();
</script>

<style>
/* Hero */
.hero {
  position: relative;
  background: var(--ink);
  color: var(--cream);
  padding: 72px 0 80px;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 80% 50%, rgba(196,68,12,0.18) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 10% 80%, rgba(26,74,122,0.20) 0%, transparent 60%);
}

.hero-inner {
  display: flex;
  align-items: center;
  gap: 64px;
  position: relative;
  z-index: 1;
}

.hero-text { flex: 1; }

.hero-eyebrow {
  font-family: var(--ff-mono);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 20px;
}

.hero-title {
  font-size: clamp(3rem, 6vw, 5.5rem);
  font-weight: 900;
  color: var(--cream);
  line-height: 1.0;
  margin-bottom: 20px;
}
.hero-title em {
  font-style: italic;
  color: var(--sienna) !important;
}

/* Global rule to ensure em styling persists through runtime updates */
:global(.hero-title em) {
  font-style: italic;
  color: var(--sienna) !important;
  animation: highlight-fade 10s ease-out infinite;
}

@keyframes highlight-fade {
  0%, 5% {
    background-color: rgba(255, 255, 255, 0.8);
  }

  10%, 100% {
    background-color: transparent;
  }
}

.hero-sub {
  font-size: 1.1rem;
  color: var(--stone);
  margin-bottom: 32px;
  max-width: 420px;
  line-height: 1.6;
}

.hero-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--ff-mono);
  font-size: 0.68rem;
  color: var(--stone);
  letter-spacing: 0.04em;
}
.stat-sep { opacity: 0.4; }
.hero-stats strong { color: var(--cream); }

/* Hero featured card */
.hero-feature {
  flex-shrink: 0;
  width: 260px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--r-lg);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: transform 0.25s, box-shadow 0.25s;
}
.hero-feature:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(0,0,0,0.3);
}
.hero-feature__art {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  border-radius: var(--r-md);
}
.hero-feature__info h3 {
  font-size: 1.1rem;
  color: var(--cream);
}
.hero-feature__info p {
  font-family: var(--ff-mono);
  font-size: 0.68rem;
  color: var(--stone);
  margin-top: 4px;
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  padding: 12px 24px;
  border-radius: var(--r-sm);
  font-family: var(--ff-mono);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  transition: all 0.2s;
  cursor: pointer;
  border: none;
}
.btn--primary {
  background: var(--sienna);
  color: white;
}
.btn--primary:hover { background: #a8380a; transform: translateY(-1px); }
.btn--outline {
  background: transparent;
  color: var(--cream);
  border: 1.5px solid rgba(255,255,255,0.3);
}
.btn--outline:hover { border-color: var(--cream); }

/* Sections */
.section { padding: 64px 0; }
.section--tinted { background: var(--sand); }

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 28px;
}
.section-title {
  font-size: 1.8rem;
}
.section-more {
  font-family: var(--ff-mono);
  font-size: 0.72rem;
  color: var(--sienna);
  letter-spacing: 0.04em;
}
.section-more:hover { text-decoration: underline; }

/* Episodes list */
.episodes-list {
  border: 1px solid var(--warm);
  border-radius: var(--r-md);
  background: white;
  padding: 0 20px;
}

/* Tag filter */
.tag-filter {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.tag-btn {
  font-family: var(--ff-mono);
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 999px;
  border: 1px solid var(--warm);
  background: white;
  color: var(--stone);
  cursor: pointer;
  transition: all 0.15s;
}
.tag-btn:hover { border-color: var(--stone); color: var(--ink); }
.tag-btn--active {
  background: var(--ink);
  color: var(--cream);
  border-color: var(--ink);
}

/* Shows grid */
.shows-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 16px;
}

/* CTA banner */
.cta-banner {
  background: var(--sienna);
  padding: 56px 0;
}
.cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
}
.cta-inner h2 {
  font-size: 1.8rem;
  color: white;
  margin-bottom: 8px;
}
.cta-inner p {
  color: rgba(255,255,255,0.75);
  font-size: 1rem;
}
.cta-banner .btn--primary {
  background: white;
  color: var(--sienna);
  flex-shrink: 0;
}
.cta-banner .btn--primary:hover { background: var(--cream); }

@media (max-width: 768px) {
  .hero-inner { flex-direction: column; }
  .hero-feature { width: 100%; flex-direction: row; }
  .hero-feature__art { width: 80px; height: 80px; }
  .shows-grid { grid-template-columns: 1fr; }
  .cta-inner { flex-direction: column; text-align: center; }
}
</style>
