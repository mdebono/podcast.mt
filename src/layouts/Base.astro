---
// src/layouts/Base.astro
import '../styles/global.css';
import { getTranslation } from '../lib/i18n.js';

const { title = 'podcast.mt', description = 'Poddati minn Malta — the Maltese podcast directory', lang = 'mt' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://podcast.mt');
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />

  <!-- Favicon placeholder -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- ── Nav ── -->
  <header class="site-nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo" aria-label="podcast.mt home">
        <span class="nav-logo__icon">🎙</span>
        <span class="nav-logo__text">podcast<span class="nav-logo__tld">.mt</span></span>
      </a>

      <nav class="nav-links" aria-label="Main navigation">
        <a href="/shows" data-i18n="nav.shows">Podcasts</a>
        <a href="/episodes" data-i18n="nav.episodes">Episodi</a>
        <a href="/submit" data-i18n="nav.submit">Ibgħat</a>
        <a href="/about" data-i18n="nav.about">Dwar</a>
      </nav>

      <div class="nav-end">
        <button id="langSwitcher" class="nav-lang-btn" aria-label="Switch language">
          {lang === 'mt' ? 'EN' : 'MT'}
        </button>
        <a href="/submit" class="nav-cta" data-i18n="nav.submitShow">+ Ibgħat Podcast</a>
      </div>
    </div>
  </header>

  <!-- ── Page content ── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ── -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="nav-logo">
          <span class="nav-logo__icon">🎙</span>
          <span class="nav-logo__text">podcast<span class="nav-logo__tld">.mt</span></span>
        </a>
        <p class="footer-tagline" data-i18n="footer.tagline">Poddati minn Malta</p>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-nav__col">
          <strong data-i18n="footer.discover">Skopri</strong>
          <a href="/shows" data-i18n="nav.shows">Podcasts</a>
          <a href="/episodes" data-i18n="sections.latestEpisodes">Episodi Riċenti</a>
        </div>
        <div class="footer-nav__col">
          <strong data-i18n="footer.creators">Kreaturi</strong>
          <a href="/submit" data-i18n="nav.submitShow">Ibgħat Podcast</a>
          <a href="/about#badge" data-i18n="footer.getBadge">Ikseb il-Badge</a>
        </div>
        <div class="footer-nav__col">
          <strong data-i18n="footer.aboutUs">Dwar</strong>
          <a href="/about" data-i18n="footer.aboutUs">Dwarna</a>
          <a href="mailto:hello@podcast.mt" data-i18n="footer.contact">Kuntatt</a>
        </div>
      </nav>
    </div>
    <div class="container footer-bottom">
      <span>© {new Date().getFullYear()} podcast.mt</span>
      <span class="footer-made" data-i18n="footer.madeWithLove">Made with ♥ in Malta 🇲🇹</span>
    </div>
  </footer>

  <script>
    import { getTranslation, getCurrentLang, setCurrentLang } from '../lib/i18n.js';

    let heroRotationTimer;

    function updateLanguage() {
      const lang = getCurrentLang();
      document.documentElement.lang = lang;

        // Update translations
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n;
        el.textContent = getTranslation(lang, key);
      });

      // Update HTML translations
      document.querySelectorAll('[data-i18n-html]').forEach(el => {
        const key = el.dataset.i18nHtml;
        el.innerHTML = getTranslation(lang, key);
      });

      // Update placeholders
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        const key = el.dataset.i18nPlaceholder;
        el.placeholder = getTranslation(lang, key);
      });

      // Update values
      document.querySelectorAll('[data-i18n-value]').forEach(el => {
        const key = el.dataset.i18nValue;
        el.value = getTranslation(lang, key);
      });

      // Update titles
      document.querySelectorAll('[data-i18n-title]').forEach(el => {
        const key = el.dataset.i18nTitle;
        el.title = getTranslation(lang, key);
      });

      // Update aria labels
      document.querySelectorAll('[data-i18n-aria-label]').forEach(el => {
        const key = el.dataset.i18nAriaLabel;
        el.setAttribute('aria-label', getTranslation(lang, key));
      });

      // Update show descriptions
      document.querySelectorAll('.show-card__desc').forEach(desc => {
        const text = desc.dataset[`desc${lang.toUpperCase()}`] || desc.dataset.descEn;
        desc.textContent = (text ?? '').slice(0, 100) + '…';
      });

      if (langBtn) {
        langBtn.textContent = lang === 'mt' ? 'EN' : 'MT';
      }

      // Start/restart hero title rotation
      startHeroTitleRotation();
    }

    function startHeroTitleRotation() {
      const heroTitle = document.querySelector('.hero-title');
      if (!heroTitle) return;

      const lang = getCurrentLang();
      const rotatingTexts = getTranslation(lang, 'hero.titleRotating');
      
      if (!Array.isArray(rotatingTexts) || rotatingTexts.length === 0) return;

      if (heroRotationTimer) {
        clearInterval(heroRotationTimer);
      }

      let currentIndex = 1;
      const emElement = heroTitle.querySelector('em');
      if (emElement) {
        emElement.textContent = rotatingTexts[0];
        emElement.style.animation = 'none';
        void emElement.offsetWidth;
        emElement.style.animation = '';
      }

      const rotateText = () => {
        if (!emElement) return;
        emElement.textContent = rotatingTexts[currentIndex];
        currentIndex = (currentIndex + 1) % rotatingTexts.length;
      };

      // Start rotation every 10 seconds
      heroRotationTimer = setInterval(rotateText, 10000);
    }

    const langBtn = document.getElementById('langSwitcher');
    if (langBtn) {
      langBtn.addEventListener('click', () => {
        const current = getCurrentLang();
        const newLang = current === 'mt' ? 'en' : 'mt';
        setCurrentLang(newLang);
        updateLanguage();
        langBtn.textContent = newLang === 'mt' ? 'EN' : 'MT';
      });
    }

    updateLanguage();
  </script>

</body>
</html>

<style>
/* Nav */
.site-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--cream);
  border-bottom: 1px solid var(--warm);
  backdrop-filter: blur(8px);
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: 32px;
  height: 60px;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--ff-head);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--ink);
  flex-shrink: 0;
}
.nav-logo__tld { color: var(--sienna); }
.nav-logo__icon { font-size: 1.1rem; }

.nav-links {
  display: flex;
  gap: 28px;
  flex: 1;
}
.nav-links a {
  font-family: var(--ff-mono);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--stone);
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--ink); }

.nav-end { margin-left: auto; }

.nav-cta {
  font-family: var(--ff-mono);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  background: var(--sienna);
  color: white;
  padding: 8px 16px;
  border-radius: var(--r-sm);
  transition: background 0.2s, transform 0.15s;
}
.nav-cta:hover { background: #a8380a; transform: translateY(-1px); }

.nav-lang-btn {
  font-family: var(--ff-mono);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  background: var(--stone);
  color: var(--cream);
  padding: 8px 12px;
  border-radius: var(--r-sm);
  border: none;
  cursor: pointer;
  transition: background 0.2s;
  margin-right: 12px;
}
.nav-lang-btn:hover { background: var(--ink); }

/* Footer */
.site-footer {
  margin-top: 96px;
  border-top: 1px solid var(--warm);
  background: var(--sand);
}

.footer-inner {
  display: flex;
  gap: 48px;
  padding: 48px 24px 32px;
  align-items: flex-start;
}

.footer-brand { flex-shrink: 0; }
.footer-tagline {
  font-family: var(--ff-mono);
  font-size: 0.7rem;
  color: var(--stone);
  letter-spacing: 0.06em;
  margin-top: 6px;
}

.footer-nav {
  display: flex;
  gap: 40px;
  margin-left: auto;
}
.footer-nav__col {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.footer-nav__col strong {
  font-family: var(--ff-mono);
  font-size: 0.68rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 4px;
}
.footer-nav__col a {
  font-size: 0.9rem;
  color: var(--ink);
  opacity: 0.7;
  transition: opacity 0.2s;
}
.footer-nav__col a:hover { opacity: 1; }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24px;
  font-family: var(--ff-mono);
  font-size: 0.68rem;
  color: var(--stone);
  letter-spacing: 0.04em;
}

@media (max-width: 640px) {
  .nav-links { display: none; }
  .footer-inner { flex-direction: column; }
  .footer-nav { flex-direction: column; gap: 24px; }
}
</style>
